# Contract Deployment (deploy.sh / Makefile)
SOROBAN_RPC=https://soroban-rpc.testnet.stellar.gateway.fm
SOROBAN_PASSPHRASE=Test SDF Network ; September 2015
# Can be a Stellar secret key (S...) or a key alias from `stellar keys`
SOROBAN_SECRET_KEY=

# Frontend (copy to frontend/.env.local)
NEXT_PUBLIC_SOROBAN_RPC=https://soroban-rpc.testnet.stellar.gateway.fm
NEXT_PUBLIC_CONTRACT_USER_REGISTRY=CDHJHY3LQWJM3PPKGFA6QRDUK2JQU5DQEBFKL42I3UEZNNM6IRFF76DJ
NEXT_PUBLIC_CONTRACT_SOCIAL_GRAPH=CC3SRPHPKC4WIEJUSQY5KKUSHCBO2Y77VDXIDRKX6XVZLHKTIOQEPULK
NEXT_PUBLIC_CONTRACT_MESSAGES=CAGETMAVXLCMB7NLZFF6TPHVAXJAQY4DQ2CTJWPQP5TL32PLQT7IVBEO

# --- Gasless / Fee-Sponsorship relayer (server-side only) ---
# Secret key of the SPONSOR account that pays users' transaction fees. The
# relayer (frontend/src/app/api/relay) signs and submits *_sponsored contract
# calls as this account, so users transact without holding any XLM.
#
# SECURITY: this is a server-only secret. Do NOT prefix it with NEXT_PUBLIC_ and
# never expose it to the browser. Put it only in frontend/.env.local (which is
# gitignored). If unset, the app transparently falls back to user-paid txs.
#
# Setup: create + fund a testnet account, then paste its secret here:
#   stellar keys generate sponsor --network testnet --fund
#   stellar keys show sponsor          # -> SXXXX... (use this value)
# or fund an existing address via https://friendbot.stellar.org/?addr=<G...>
SPONSOR_SECRET=

# --- Relayer abuse protection (all optional; sensible defaults applied) ---
# These bound how much the sponsor can ever spend, which is critical on mainnet
# where fees are real money. Limits reset each UTC day.
#   Max sponsored actions per address per day (default 30)
RELAY_MAX_ACTIONS_PER_ADDRESS_PER_DAY=30
#   Max registrations per address per day — cheapest action to spam (default 3)
RELAY_MAX_REGISTRATIONS_PER_ADDRESS_PER_DAY=3
#   Reject any single tx whose max fee exceeds this many XLM (default 0.5)
RELAY_MAX_FEE_PER_TX_XLM=0.5
#   Hard global daily spend ceiling in XLM — relayer stops when reached (default 50)
RELAY_DAILY_XLM_CAP=50
#   Optional comma-separated Origin allowlist; unset = allow all (dev). e.g.
#   RELAY_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
RELAY_ALLOWED_ORIGINS=
